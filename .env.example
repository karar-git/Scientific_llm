# OpenRouter (chat + embeddings both go through it)
OPENROUTER_API_KEY=put_your_openrouter_api_key_here
# Any tool-calling-capable model works. deepseek-v4-flash is the cheap default;
# openai/gpt-5-mini is a sturdier (pricier) alternative.
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Storage
CHROMA_DIR=.chroma
CHROMA_COLLECTION=papers
CHUNKS_PATH=data/chunks.jsonl
MANIFEST_PATH=data/papers_manifest.json

# Ingestion
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
USE_MARKER=false

# Retrieval
RETRIEVAL_K=10
RERANK_K=4
WEB_SEARCH_ENABLED=true
